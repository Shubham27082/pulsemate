generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  CLINIC_OWNER
  DOCTOR
  RECEPTIONIST
  SUPER_ADMIN
}

enum ApprovalStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum AdminLevel {
  ROOT
  SUPER_ADMIN
  SUPPORT
  FINANCE
}

enum AppointmentType {
  ONLINE
  OFFLINE
}

enum AppointmentStatus {
  PENDING_PAYMENT
  BOOKED
  CHECKED_IN
  IN_QUEUE
  CALLED
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum QueueStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum QueueItemStatus {
  WAITING
  CALLED
  IN_CONSULTATION
  COMPLETED
  SKIPPED
  CANCELLED
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  RESET_PASSWORD
  VERIFY_MOBILE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  CASH
  UPI
}

enum StaffRole {
  OWNER
  DOCTOR
  RECEPTIONIST
}

enum ClinicInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  REMOVED
}

model User {
  id             String         @id @default(uuid())
  name           String?
  mobile         String         @unique
  email          String?        @unique
  role           UserRole       @default(PATIENT)
  approvalStatus ApprovalStatus @default(VERIFIED)
  passwordHash   String?
  rejectionReason String?
  suspendedReason String?
  isActive       Boolean        @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  patientProfile      PatientProfile?
  doctorProfile       DoctorProfile?
  receptionistProfile ReceptionistProfile?
  adminProfile        AdminProfile?
  ownedClinics        Clinic[]              @relation("ClinicOwner")
  clinicStaff         ClinicStaff[]
  appointments        Appointment[]         @relation("PatientAppointments")
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]            @relation("AuditActor")
  queueItems          QueueItem[]           @relation("PatientQueueItems")
  prescriptions       Prescription[]        @relation("PatientPrescriptions")
  payments            Payment[]             @relation("PatientPayments")
  fcmTokens           FcmToken[]
  createdAdmins       AdminProfile[]        @relation("AdminCreator")
  createdReceptionists ReceptionistProfile[] @relation("OwnerCreatedReceptionists")

  @@map("users")
}

model PatientProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  age               Int?
  dob               DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  emergencyContact  String?
  bloodGroup        String?
  allergies         String?
  existingDiseases  String?
  insuranceProvider String?
  profileCompleted  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model Clinic {
  id                    String         @id @default(uuid())
  name                  String
  ownerId               String
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  pincode               String?
  latitude              Float?
  longitude             Float?
  isVerified            Boolean        @default(false)
  approvalStatus        ApprovalStatus @default(PENDING)
  rejectionReason       String?
  isActive              Boolean        @default(true)
  openingTime           String?
  closingTime           String?
  openingHours          String?
  description           String?
  clinicLicenseDocument String?
  gstNumber             String?
  specialties           String[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  owner              User                 @relation("ClinicOwner", fields: [ownerId], references: [id])
  staff              ClinicStaff[]
  doctorClinics      DoctorClinic[]       @relation("MarketplaceClinic")
  appointments       Appointment[]
  queues             Queue[]
  receptionistProfiles ReceptionistProfile[]

  @@map("clinics")
}

model ClinicStaff {
  id        String    @id @default(uuid())
  clinicId  String
  userId    String
  role      StaffRole
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId])
  @@map("clinic_staff")
}

model DoctorProfile {
  id                        String         @id @default(uuid())
  userId                    String         @unique
  approvalStatus            ApprovalStatus @default(PENDING)
  qualification             String?
  specialization            String?
  experienceYears           Int?           @default(0)
  education                 String?
  consultationFee           Float?         @default(0)
  onlineAvailable           Boolean        @default(false)
  offlineAvailable          Boolean        @default(true)
  bio                       String?
  avgConsultationMins       Int            @default(10)
  medicalRegistrationNumber String?        @unique
  certificates              Json?
  languagesKnown            String[]
  marketplaceVisible        Boolean        @default(false)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorClinics DoctorClinic[] @relation("MarketplaceDoctor")
  appointments  Appointment[]
  queues        Queue[]
  prescriptions Prescription[]

  @@map("doctor_profiles")
}

model ReceptionistProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  assignedClinicId String
  createdByOwnerId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedClinic Clinic @relation(fields: [assignedClinicId], references: [id], onDelete: Cascade)
  createdByOwner User   @relation("OwnerCreatedReceptionists", fields: [createdByOwnerId], references: [id])

  @@map("receptionist_profiles")
}

model AdminProfile {
  id          String     @id @default(uuid())
  userId      String     @unique
  level       AdminLevel
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy User? @relation("AdminCreator", fields: [createdById], references: [id])

  @@map("admin_profiles")
}

model DoctorClinic {
  id                  String            @id @default(uuid())
  doctorId            String
  clinicId            String
  inviteStatus        ClinicInviteStatus @default(PENDING)
  roleAtClinic        String?           @default("CONSULTANT")
  consultationFee     Float?
  availableDays       String[]
  startTime           String?
  endTime             String?
  avgConsultationMins Int               @default(10)
  isActive            Boolean           @default(true)
  joinedAt            DateTime?
  removedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  doctor DoctorProfile @relation("MarketplaceDoctor", fields: [doctorId], references: [id], onDelete: Cascade)
  clinic Clinic        @relation("MarketplaceClinic", fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([doctorId, clinicId])
  @@map("clinic_doctors")
}

model Appointment {
  id                   String            @id @default(uuid())
  patientId            String
  doctorId             String
  clinicId             String
  appointmentType      AppointmentType   @default(OFFLINE)
  appointmentDate      DateTime
  slotTime             String?
  status               AppointmentStatus @default(BOOKED)
  queueNumber          Int?
  estimatedWaitMinutes Int?
  symptoms             String?
  notes                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  patient      User          @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id])
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  queueItem    QueueItem?
  prescription Prescription?
  payment      Payment?

  @@map("appointments")
}

model Queue {
  id        String      @id @default(uuid())
  clinicId  String
  doctorId  String
  date      DateTime    @db.Date
  status    QueueStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  clinic     Clinic        @relation(fields: [clinicId], references: [id])
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id])
  queueItems QueueItem[]

  @@unique([clinicId, doctorId, date])
  @@map("queues")
}

model QueueItem {
  id            String          @id @default(uuid())
  queueId       String
  appointmentId String?         @unique
  patientId     String
  queueNumber   Int
  status        QueueItemStatus @default(WAITING)
  position      Int
  isFollowUp    Boolean         @default(false)
  followUpOf    String?
  calledAt      DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  queue       Queue        @relation(fields: [queueId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  patient     User         @relation("PatientQueueItems", fields: [patientId], references: [id])

  @@map("queue_items")
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  authRole         UserRole
  deviceInfo       String?
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  lastUsedAt       DateTime  @default(now())
  isRevoked        Boolean   @default(false)
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, authRole, isRevoked])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model OtpVerification {
  id         String     @id @default(uuid())
  mobile     String
  purpose    OtpPurpose @default(LOGIN)
  otpHash    String
  expiresAt  DateTime
  attempts   Int        @default(0)
  verifiedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([mobile, purpose, createdAt])
  @@map("otp_verifications")
}

model Prescription {
  id               String   @id @default(uuid())
  appointmentId    String   @unique
  doctorId         String
  patientId        String
  diagnosis        String?
  medicines        Json
  instructions     String?
  followUpDate     DateTime?
  requiresFollowUp Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointment Appointment   @relation(fields: [appointmentId], references: [id])
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  patient     User          @relation("PatientPrescriptions", fields: [patientId], references: [id])

  @@map("prescriptions")
}

model Payment {
  id                String        @id @default(uuid())
  appointmentId     String        @unique
  patientId         String
  amount            Float
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod @default(RAZORPAY)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     User        @relation("PatientPayments", fields: [patientId], references: [id])

  @@map("payments")
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fcm_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation("AuditActor", fields: [userId], references: [id])

  @@map("audit_logs")
}
