# ─── Database (Railway PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres:XHAHBeVRHDFaSGNNozGOXWADzjYBzgwr@postgres.railway.internal:5432/railway"

# ─── JWT Secrets (generate strong random strings) ────────────────────────────
JWT_ACCESS_SECRET="pulsemate-super-secret-access-key-min-32-chars-change-in-prod"
JWT_REFRESH_SECRET="pulsemate-super-secret-refresh-key-min-32-chars-change-in-prod"

# ─── Token Expiry ─────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET="pulsemate-cookie-secret-change-in-prod"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL="https://your-frontend.railway.app"

# ─── OTP Provider ─────────────────────────────────────────────────────────────
# console = logs OTP to terminal (dev/demo mode, no SMS sent)
OTP_PROVIDER=console

# ─── Email Provider ───────────────────────────────────────────────────────────
# console = logs emails to terminal (dev/demo mode, no email sent)
EMAIL_PROVIDER=console

# ─── Resend (optional — for real emails) ─────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Twilio (optional — for real SMS OTP) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── OTP Settings ─────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ─── Email Verification Settings ─────────────────────────────────────────────
EMAIL_VERIFICATION_EXPIRY_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# ─── Razorpay (leave blank for dev mode — auto-verifies payments) ─────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Firebase (leave blank for dev mode) ─────────────────────────────────────
FIREBASE_SERVER_KEY=
