# Database
DATABASE_URL="postgresql://postgres:root@localhost:5432/pulsemate_db"

# JWT Secrets
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"

# Token Expiry
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Cookie
COOKIE_SECRET="your-cookie-secret-key"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# OTP Provider (twilio | msg91 | fast2sms | console)
OTP_PROVIDER=console

# Email Provider (smtp | resend | sendgrid | mailgun | console)
EMAIL_PROVIDER=resend

# Resend (recommended for transactional clinic emails)
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="PulseMate <noreply@your-domain.com>"

# SMTP Email (optional fallback)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-gmail-app-password"
# SMTP_FROM_EMAIL="PulseMate <your-email@gmail.com>"
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# Twilio (if OTP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# MSG91 (if OTP_PROVIDER=msg91)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# Fast2SMS (if OTP_PROVIDER=fast2sms)
FAST2SMS_API_KEY=

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Email Verification Settings
EMAIL_VERIFICATION_EXPIRY_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# ─── Razorpay (Payment) ───────────────────────────────────────────────────────
# Leave blank to use dev mode (auto-verify, no real payment)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Firebase Cloud Messaging (Push Notifications) ───────────────────────────
# Backend push notifications use Firebase Admin SDK (NOT the legacy Server Key).
# Paste your Firebase service account JSON as a single-line string below.
# Leave blank to fall back to console-only logging in dev mode.
# How to get it: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Firebase Legacy Server Key (DEPRECATED — do not use) ────────────────────
# Only kept here for reference. fcm.service.js uses FIREBASE_SERVICE_ACCOUNT_JSON above.
# FIREBASE_SERVER_KEY=

# ─── SMS Provider (for OTP) ──────────────────────────────────────────────────
# Supported values: mock | msg91 | 2factor | twilio
#
# mock    → OTP printed to backend console only. Use this for local dev.
# msg91   → Recommended for India production. Sign up at https://msg91.com
# 2factor → Simple India SMS. Sign up at https://2factor.in
# twilio  → International SMS. Sign up at https://twilio.com
#
# ── MSG91 setup ───────────────────────────────────────────────────────────────
#  1. Sign up at https://msg91.com (free trial available)
#  2. Go to: Dashboard → API → Auth Key  → copy here as SMS_API_KEY
#  3. Go to: Dashboard → Sender ID → Create → use "PULSE" (6 chars) → SMS_SENDER_ID
#  4. Complete DLT registration (mandatory for India SMS, takes 1-2 days)
#     Your telecom must be registered on TRAI DLT portal first.
#  5. Go to: MSG91 Dashboard → SMS → Templates → Add Template
#     Template text: "Your PulseMate OTP is ##OTP##. Valid for 5 min. Do not share. -PULSE"
#     After DLT approval, copy the Template ID → SMS_TEMPLATE_ID
#
# ── 2Factor setup ─────────────────────────────────────────────────────────────
#  1. Sign up at https://2factor.in (₹200 free credits on signup)
#  2. Dashboard → API Keys → copy here as SMS_API_KEY
#  3. Leave SMS_TEMPLATE_ID blank to use 2Factor's default OTP template
#     OR create a custom template and put the name in SMS_TEMPLATE_ID
#  4. SMS_SENDER_ID is not used by 2Factor — leave blank
#
# ── Twilio setup ──────────────────────────────────────────────────────────────
#  1. Sign up at https://twilio.com
#  2. Console → Account SID + Auth Token
#     Set SMS_API_KEY as "ACCOUNT_SID:AUTH_TOKEN"  (joined with colon)
#  3. Buy a phone number → put it in SMS_SENDER_ID (e.g. +12015551234)
# ─────────────────────────────────────────────────────────────────────────────
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=PULSE
SMS_TEMPLATE_ID=
