# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Change credentials to match your local setup.
DATABASE_URL="postgresql://postgres:root@localhost:5432/pulsemate_db"

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET="your-cookie-secret-key"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ─── SMS / OTP Provider ───────────────────────────────────────────────────────
# Supported values: mock | 2factor | msg91 | twilio
#
#   mock    → OTP printed to backend console only (use for local dev, no API key needed)
#   2factor → Simple India SMS. Sign up at https://2factor.in  (₹200 free credits)
#   msg91   → India production. Sign up at https://msg91.com
#   twilio  → International SMS. Sign up at https://twilio.com
#
# ── Quick start for local dev ─────────────────────────────────────────────────
#   Set SMS_PROVIDER=mock and leave SMS_API_KEY blank.
#   The OTP will print in the backend terminal — copy-paste it into the app.
#
# ── 2Factor setup (recommended for India) ────────────────────────────────────
#   1. Sign up at https://2factor.in
#   2. Dashboard → API Keys → copy key → SMS_API_KEY
#   3. Leave SMS_TEMPLATE_ID blank (uses default OTP template)
#   4. SMS_SENDER_ID not used by 2Factor — leave blank
#
# ── MSG91 setup ───────────────────────────────────────────────────────────────
#   1. Sign up at https://msg91.com
#   2. Dashboard → API → Auth Key → SMS_API_KEY
#   3. Dashboard → Sender IDs → create "PULSE" → SMS_SENDER_ID
#   4. Dashboard → SMS Templates → create DLT-approved template → SMS_TEMPLATE_ID
#
# ── Twilio setup ──────────────────────────────────────────────────────────────
#   1. Sign up at https://twilio.com
#   2. Console → Account SID + Auth Token
#      Set SMS_API_KEY="ACCOUNT_SID:AUTH_TOKEN" (joined with colon)
#   3. Buy a phone number → SMS_SENDER_ID (e.g. +12015551234)
# ─────────────────────────────────────────────────────────────────────────────
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=
SMS_TEMPLATE_ID=
OTP_PROVIDER=mock

# ─── WhatsApp OTP (optional) ──────────────────────────────────────────────────
# When set, OTP is sent on BOTH SMS and WhatsApp simultaneously.
# Leave WHATSAPP_PROVIDER blank to disable WhatsApp delivery.
#
# Option 1 — 2Factor WhatsApp (easiest, same API key as SMS):
#   1. Login to https://2factor.in → Dashboard → WhatsApp → Enable
#   2. Set WHATSAPP_PROVIDER=2factor
#   3. Leave WHATSAPP_TEMPLATE_ID blank (uses default) or set custom template name
#
# Option 2 — Twilio WhatsApp:
#   1. Twilio Console → Messaging → WhatsApp Sandbox (free test)
#      OR buy a WhatsApp-enabled number for production
#   2. Set WHATSAPP_PROVIDER=twilio
#   3. Set TWILIO_WHATSAPP_FROM=whatsapp:+14155238886 (sandbox number)
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER=
WHATSAPP_TEMPLATE_ID=
TWILIO_WHATSAPP_FROM=

# ─── Twilio (if SMS_PROVIDER=twilio or WHATSAPP_PROVIDER=twilio) ──────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── MSG91 (if SMS_PROVIDER=msg91) ────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# ─── OTP Settings ─────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ─── Email Provider ───────────────────────────────────────────────────────────
# Supported values: console | resend | smtp | sendgrid | mailgun
# Use "console" for local dev (emails printed to terminal, no API key needed)
EMAIL_PROVIDER=console

# Resend (recommended for production transactional emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL="PulseMate <noreply@your-domain.com>"

# SMTP (optional fallback — works with Gmail, Outlook, etc.)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-gmail-app-password"
# SMTP_FROM_EMAIL="PulseMate <your-email@gmail.com>"

# ─── Email Verification Settings ──────────────────────────────────────────────
EMAIL_VERIFICATION_EXPIRY_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# ─── Razorpay (Payments) ──────────────────────────────────────────────────────
# Leave blank to use dev mode (auto-verify payments, no real money)
# Get keys at https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Firebase Admin SDK (Push Notifications) ──────────────────────────────────
# Required for sending push notifications to mobile app via FCM.
# Leave blank to disable push notifications (app still works without it).
#
# How to get it:
#   1. Go to https://console.firebase.google.com
#   2. Select your project → Project Settings (gear icon)
#   3. Service Accounts tab → Generate new private key → downloads a JSON file
#   4. Open the JSON file, copy ALL contents, minify to a single line
#      (remove all newlines), then paste here.
#   NOTE: The private_key field has \n characters — keep them as \n (escaped),
#         do NOT expand them into real newlines.
FIREBASE_SERVICE_ACCOUNT_JSON=
